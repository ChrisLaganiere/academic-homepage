---
interface Props {
  listTitle: string;
  listItems: {
    title: string;
    link: string;
  }[];
}
const { listTitle, listItems } = Astro.props
---
<div>
    <h2 class="text-2xl font-bold mb-6">{listTitle}</h2>
    <div>
    {
        listItems.map((item) => (
        <a href={item.link} target="_blank" class="p-6 text-base-content">
            <p class="mb-3">{item.title}</p>
        </a>
        ))
    }
    </div>
</div>
