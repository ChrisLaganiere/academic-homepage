---
import { Image } from 'astro:assets'

import SocialIcons from './SocialIcons.astro'
import { template } from '@/settings'


const {fullName, title, institute, profilePicture} = Astro.props
---
<div class='flex-1'>
  <h1 class='text-4xl font-bold mb-4'>
    <span class='text-secondary'>About Me</span>
  </h1>
  <p class='text-xl text-gray-600 mb-4'>{title}{institute ? ` at ${institute}` : ''}</p>
  <p class='text-lg mb-6'>
    CS master's candidate participating in Stanford NDO
  </p>
  <a href={`${template.base}/documents/masters-plan.pdf`} target="_blank" class="text-lg mb-6">
    <p class="text-lg mb-6 text-secondary">Plan and Timeline</p>
  </a>
  <a href={`${template.base}/documents/resume.pdf`} target="_blank" class="text-lg mb-6">
    <p class="text-lg mb-6 text-secondary">Resume</p>
  </a>
  <div class='flex gap-4'>
    <SocialIcons />
  </div>
</div>
<div class='size-72 lg:block hidden'>
  <!-- Add your profile image -->
  <Image
    src={profilePicture}
    alt={fullName}
    class='w-full h-full mask mask-circle size-44'
  />
</div>